# BUILD-TIME variable — baked into the JS bundle at `next build`.
# Changing this value requires a full rebuild, NOT just a restart.
NEXT_PUBLIC_API_URL=http://localhost/api

# BUILD-TIME variable — browser-accessible MinIO/S3 hostname.
NEXT_PUBLIC_MEDIA_HOST=http://localhost:9000

# Runtime — internal Docker hostname for Next.js server-side image fetching.
INTERNAL_MEDIA_HOST=http://minio:9000

# Cache revalidation secret — must match the NestJS API's REVALIDATE_SECRET.
REVALIDATE_SECRET=replace-me

# Set to "true" in all non-production environments to block all crawlers.
ROBOTS_DISALLOW_ALL=true

# Node environment
NODE_ENV=development
