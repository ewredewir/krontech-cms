# ─── DATABASE ───────────────────────────────────────────────────
POSTGRES_USER=krontech
POSTGRES_PASSWORD=krontech_dev_password
POSTGRES_DB=krontech
DATABASE_URL=postgresql://krontech:krontech_dev_password@postgres:5432/krontech

# ─── REDIS ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── OBJECT STORAGE (MinIO in dev / S3 in prod) ─────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_dev_password
S3_ENDPOINT=http://minio:9000
S3_BUCKET=krontech-media
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_dev_password

# ─── AUTH ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-with-secure-random-string
JWT_REFRESH_SECRET=replace-with-different-secure-random-string

# ─── CACHE REVALIDATION ─────────────────────────────────────────
REVALIDATE_SECRET=replace-me-with-random-string

# ─── SPAM PROTECTION ────────────────────────────────────────────
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA  # Cloudflare test key

# ─── BUILD-TIME variables — baked into the JS bundle at `docker compose build`.
# Changing these values requires a full container rebuild (`docker compose up --build`),
# NOT just a restart (`docker compose restart`).
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_MEDIA_HOST=http://localhost:9000

# ─── RUNTIME (server-side only, NOT baked into bundle) ──────────
# Internal Docker hostname for MinIO — used by Next.js server-side image fetching.
# In production, set both INTERNAL_MEDIA_HOST and NEXT_PUBLIC_MEDIA_HOST to the real S3/CDN URL.
INTERNAL_MEDIA_HOST=http://minio:9000

# ─── ENVIRONMENT ────────────────────────────────────────────────
NODE_ENV=development

# ─── CRAWLERS — set to "true" in ALL non-production environments ─
# Outputs `Disallow: /` for all crawlers when true.
ROBOTS_DISALLOW_ALL=true
