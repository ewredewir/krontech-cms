# ─── DATABASE ───────────────────────────────────────────────────
POSTGRES_USER=krontech
POSTGRES_PASSWORD=krontech_dev_password
POSTGRES_DB=krontech
# Host-machine URL — used by local `prisma migrate dev` and test runners outside Docker
DATABASE_URL=postgresql://krontech:krontech_dev_password@localhost:5433/krontech
# Docker-internal URL — used by the `api` and `migrator` containers (service name, not localhost)
DOCKER_DATABASE_URL=postgresql://krontech:krontech_dev_password@postgres:5432/krontech

# ─── REDIS ──────────────────────────────────────────────────────
# Host-machine URL — used by test runners outside Docker
REDIS_URL=redis://localhost:6379
# Docker-internal URL — used by the `api` container
DOCKER_REDIS_URL=redis://redis:6379

# ─── OBJECT STORAGE (MinIO in dev / S3 in prod) ─────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_dev_password
S3_ENDPOINT=http://minio:9000
S3_BUCKET=krontech-media
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_dev_password

# ─── AUTH ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-with-secure-random-string
JWT_REFRESH_SECRET=replace-with-different-secure-random-string

# ─── CACHE REVALIDATION ─────────────────────────────────────────
REVALIDATE_SECRET=replace-me-with-random-string

# ─── SPAM PROTECTION ────────────────────────────────────────────
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA  # Cloudflare test key

# ─── BUILD-TIME variables — baked into the JS bundle at `docker compose build`.
# Changing these values requires a full container rebuild (`docker compose up --build`),
# NOT just a restart (`docker compose restart`).
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_MEDIA_HOST=http://localhost:9000

# ─── RUNTIME (server-side only, NOT baked into bundle) ──────────
# Internal Docker hostname for MinIO — used by Next.js server-side image fetching.
# In production, set both INTERNAL_MEDIA_HOST and NEXT_PUBLIC_MEDIA_HOST to the real S3/CDN URL.
INTERNAL_MEDIA_HOST=http://minio:9000
# Runtime — internal Docker hostname for the NestJS API — used by Next.js SSR/ISR fetches.
# Must point directly to the api container (not nginx) so that 'next build' can fetch data
# before nginx starts. The '/api' segment matches NestJS globalPrefix('api/v1').
# docker-compose.yml hardcodes this value; this entry is for documentation only.
INTERNAL_API_URL=http://api:3001/api
# Internal Docker URL of the Next.js web container — used by the NestJS API to POST /api/revalidate
# for ISR cache invalidation. Must be a direct container-to-container URL, NOT via nginx (which
# routes /api/* to NestJS, not Next.js). In production, change to the web container's internal hostname.
WEB_INTERNAL_URL=http://localhost:3000
# Public-facing web origin used by the API to build preview links for the browser.
WEB_PUBLIC_URL=http://localhost

# ─── ENVIRONMENT ────────────────────────────────────────────────
NODE_ENV=development

# ─── CRAWLERS — set to "true" in ALL non-production environments ─
# Outputs `Disallow: /` for all crawlers when true.
ROBOTS_DISALLOW_ALL=true

# ─── STANDALONE FRONTEND DEV (no Docker) ────────────────────────
# Set to "true" in .env.local ONLY when running the web app standalone
# without a running API (e.g. pnpm dev in apps/web with no Docker stack).
# Never set in Docker Compose — this would hide real API errors.
# NEXT_PUBLIC_USE_FIXTURES=true
