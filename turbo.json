{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_MEDIA_HOST"],
      "passThroughEnv": ["INTERNAL_API_URL", "INTERNAL_MEDIA_HOST", "REVALIDATE_SECRET", "NODE_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": [],
      "dependsOn": ["^build"]
    },
    "typecheck": { "dependsOn": ["^build"], "outputs": [] }
  }
}
